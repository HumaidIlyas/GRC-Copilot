# ── LLM Vendor ────────────────────────────────────────────────────────────────
# Options: anthropic (default) | openai | gemini | vertex
# "vertex" uses Claude on Google Cloud Vertex AI — auth via GCP service account
LLM_VENDOR=anthropic

# ── API Keys (only the active vendor's key is required) ───────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...

# ── Vertex AI (when LLM_VENDOR=vertex) ────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-east5

# ── NVD API (optional — raises rate limit from 5 to 50 req/30s) ───────────────
# Register free at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# Local:  sqlite:///./grc_copilot.db
# GCP:    postgresql://user:pass@/dbname?host=/cloudsql/project:region:instance
DATABASE_URL=sqlite:///./grc_copilot.db

# ── Cloud Storage (optional — for GCP export storage) ─────────────────────────
# GCS_BUCKET=your-grc-copilot-bucket
